# ELM OpenAI-compatible API
ELM_API_KEY=replace-with-elm-api-key
ELM_CHAT_MODEL=gpt-5.4-nano-2026-03-17
ELM_EMBED_MODEL=text-embedding-3-small

# Local auth session signing. Use a long random value outside local development.
AUTH_SECRET=replace-with-random-auth-secret

# GitBook v1 knowledge source.
# GITBOOK_SPACE is the space id from https://app.gitbook.com/o/<org_id>/s/<space_id>,
# not the public docs URL. The organization id is not needed for the v1 single-space ingest.
GITBOOK_TOKEN=replace-with-gitbook-token
GITBOOK_SPACE=replace-with-gitbook-space-id

# Local Postgres + pgvector
POSTGRES_USER=vioscope
POSTGRES_PASSWORD=vioscope_dev
POSTGRES_DB=vioscope
POSTGRES_PORT=5432
DATABASE_URL=postgresql://vioscope:vioscope_dev@localhost:5432/vioscope
WIKI_VECTOR_INDEX=wiki_chunks
WIKI_VECTOR_DIMENSION=1536
WIKI_CHUNK_SIZE=3200
WIKI_CHUNK_OVERLAP=400
WIKI_EMBED_BATCH_SIZE=32
WIKI_MIN_SCORE=0.35
# Optional: override Mastra runtime storage with an absolute file: URL.
# Defaults to DATASTORE_DIR/runtime/mastra.db when DATASTORE_DIR is set.
# MASTRA_STORAGE_URL=file:/absolute/path/to/mastra.db

# Internal VioScope content root on EIDF; keep the actual content outside this repo.
DATASTORE_DIR=/Public

# A2/B1 lab state model. Defaults to DATASTORE_DIR/lab-state.yaml when unset.
# LAB_STATE_PATH=/path/to/local/university-gitlab/clone/lab-state.yaml
THEME_MEETING_STALE_DAYS=14
THEME_MEETING_DEEP_DIVE_WEEKS=3
# Theme meeting planner. Config is read-only operational setup; updates and notifications are user/runtime state.
# THEME_MEETING_CONFIG_PATH=/path/to/local/university-gitlab/clone/theme-meeting-config.yaml
# THEME_MEETING_UPDATES_PATH=/path/to/local/university-gitlab/clone/theme-meeting-updates.yaml
# THEME_MEETING_NOTIFICATIONS_PATH=/path/to/local/university-gitlab/clone/theme-meeting-notifications.yaml

# Optional external public profile cache generated from https://vios.science/team/.
# This is only for profile-only user seeds; it does not create login access unless applied and confirmed.
TEAM_PROFILE_MARKDOWN=/Public/team/vios-team-public.md

# User-scoped runtime material lives under DATASTORE_DIR/users/<source-id-without-.md>/.
# Example: /Public/users/alice/profile.md, memory.md, files/, sessions/.

# Runtime Agent Skills. Can point at a Vios-Research-Skills clone, a private fork,
# or multiple roots separated by your OS path delimiter. Later roots override earlier roots.
# If unset, this defaults to DATASTORE_DIR/skills/vios-research-skills:DATASTORE_DIR/skills/vios-private-skills.
VIOS_SKILLS_DIR=/Public/skills/vios-research-skills:/Public/skills/vios-private-skills

# B2 submission review harness limits
SUBMISSION_REVIEW_MAX_DRAFT_CHARS=60000
SUBMISSION_REVIEW_MAX_OUTPUT_TOKENS=5000
SUBMISSION_REVIEW_MAX_DECK_BYTES=26214400
# Optional: uploaded draft/deck scratch space. Defaults to DATASTORE_DIR/uploads/submission-review.
# SUBMISSION_REVIEW_UPLOAD_DIR=/Public/uploads/submission-review
